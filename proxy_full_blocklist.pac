    for (var i = 0; i < b.length; i++) {
        if (dnsDomainIs(host, b[i])) {
            return "DIRECT";
        }
    }

    // 5. Selective routing
    if (shExpMatch(host, "*.gnunet") || dnsDomainIs(host, "gnunet.org")) {
        return "PROXY 127.0.0.1:7776";
    }
    if (shExpMatch(host, "*.freenet") || dnsDomainIs(host, "freenetproject.org")) {
        return "PROXY 127.0.0.1:8888";
    }
    if (shExpMatch(host, "*.i2p") || 
        dnsDomainIs(host, "protonmail.com") || 
        dnsDomainIs(host, "tutanota.com") || 
        dnsDomainIs(host, "riseup.net")) {
        return "SOCKS5 127.0.0.1:4447";
    }
    if (shExpMatch(host, "*.onion") || 
        dnsDomainIs(host, "signal.org") || 
        dnsDomainIs(host, "duckduckgo.com")) {
        return "SOCKS5 127.0.0.1:9050";
    }

    // 6. Rotire automată pentru restul traficului
    return getNextProxy();
}
